{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$defs" : {
    "CoreEnv" : {
      "type" : "object",
      "properties" : {
        "name" : {
          "type" : "string",
          "title" : "fields.name.title",
          "description" : "fields.name.description",
          "minLength" : 1
        },
        "value" : {
          "type" : "string",
          "title" : "fields.value.title",
          "description" : "fields.value.description",
          "minLength" : 1
        }
      },
      "required" : [ "name", "value" ]
    },
    "CoreResource" : {
      "type" : "object",
      "properties" : {
        "cpu" : {
          "type" : "string",
          "title" : "fields.cpu.title",
          "description" : "fields.cpu.description",
          "pattern" : "^\\d+([a-zA-Z]+)?$"
        },
        "disk" : {
          "type" : "string",
          "title" : "fields.disk.title",
          "description" : "fields.disk.description",
          "pattern" : "^\\d+([a-zA-Z]+)?$"
        },
        "gpu" : {
          "type" : "string",
          "title" : "fields.gpu.title",
          "description" : "fields.gpu.description",
          "pattern" : "^\\d+([a-zA-Z]+)?$"
        },
        "mem" : {
          "type" : "string",
          "title" : "fields.mem.title",
          "description" : "fields.mem.description",
          "pattern" : "^\\d+([a-zA-Z]+)?$"
        }
      }
    },
    "CoreServiceType" : {
      "type" : "string",
      "enum" : [ "ExternalName", "ClusterIP", "NodePort", "LoadBalancer" ]
    },
    "CoreVolume" : {
      "type" : "object",
      "properties" : {
        "mount_path" : {
          "type" : "string",
          "title" : "fields.mountPath.title",
          "description" : "fields.mountPath.description",
          "minLength" : 1
        },
        "name" : {
          "type" : "string",
          "title" : "fields.name.title",
          "description" : "fields.name.description",
          "minLength" : 1
        },
        "spec" : {
          "$ref" : "#/$defs/Map_String.String_",
          "title" : "fields.spec.title",
          "description" : "fields.spec.description",
          "additionalProperties" : {
            "type" : "string",
            "title" : "fields.spec.item.title",
            "description" : "fields.spec.item.description"
          }
        },
        "volume_type" : {
          "$ref" : "#/$defs/VolumeType",
          "title" : "fields.volumeType.title",
          "description" : "fields.volumeType.description"
        }
      },
      "required" : [ "mount_path", "name", "volume_type" ]
    },
    "HuggingfaceBackend" : {
      "type" : "string",
      "enum" : [ "AUTO", "VLLM", "HUGGINGFACE" ]
    },
    "HuggingfaceDType" : {
      "type" : "string",
      "enum" : [ "AUTO", "FLOAT16", "FLOAT32", "BFLOAT16", "FLOAT", "HALF" ]
    },
    "HuggingfaceTask" : {
      "type" : "string",
      "enum" : [ "sequence_classification", "token_classification", "fill_mask", "text_generation", "text2text_generation", "text_embedding" ]
    },
    "Map_String.String_" : {
      "type" : "object",
      "additionalProperties" : {
        "type" : "string"
      }
    },
    "VolumeType" : {
      "type" : "string",
      "enum" : [ "shared_volume", "persistent_volume_claim", "ephemeral", "empty_dir", "image" ]
    }
  },
  "type" : "object",
  "properties" : {
    "args" : {
      "title" : "fields.huggingface.args.title",
      "description" : "fields.huggingface.args.description",
      "type" : "array",
      "items" : {
        "type" : "string",
        "title" : "fields.args.item.title",
        "description" : "fields.args.item.description"
      }
    },
    "local_execution" : {
      "type" : "boolean",
      "title" : "fields.localExecution.title",
      "description" : "fields.localExecution.description"
    },
    "path" : {
      "type" : "string",
      "title" : "fields.path.title",
      "description" : "fields.huggingface.path.description",
      "pattern" : "^(store://([^/]+)/model/huggingface/.*)|.*/$|.*\\.zip$|^huggingface?://.*$|^hf?://.*$"
    },
    "task" : {
      "type" : "string",
      "title" : "fields.task.title",
      "description" : "fields.task.description",
      "minLength" : 1
    }
  },
  "required" : [ "task" ],
  "title" : "specs.huggingfaceserve+serve:run.title",
  "description" : "specs.huggingfaceserve+serve:run.description",
  "allOf" : [ {
    "type" : "object",
    "properties" : {
      "backend" : {
        "$ref" : "#/$defs/HuggingfaceBackend",
        "title" : "fields.huggingface.backend.title",
        "description" : "fields.huggingface.backend.description"
      },
      "disable_log_requests" : {
        "type" : "boolean",
        "title" : "fields.huggingface.disablelogrequests.title",
        "description" : "fields.huggingface.disablelogrequests.description"
      },
      "disable_lower_case" : {
        "type" : "boolean",
        "title" : "fields.huggingface.disablelowercase.title",
        "description" : "fields.huggingface.disablelowercase.description"
      },
      "disable_special_tokens" : {
        "type" : "boolean",
        "title" : "fields.huggingface.disablespecialtokens.title",
        "description" : "fields.huggingface.disablespecialtokens.description"
      },
      "dtype" : {
        "$ref" : "#/$defs/HuggingfaceDType",
        "title" : "fields.huggingface.dtype.title",
        "description" : "fields.huggingface.dtype.description"
      },
      "envs" : {
        "title" : "fields.envs.title",
        "description" : "fields.envs.description",
        "type" : "array",
        "items" : {
          "$ref" : "#/$defs/CoreEnv",
          "title" : "fields.envs.item.title",
          "description" : "fields.envs.item.description"
        }
      },
      "function" : {
        "type" : "string",
        "title" : "fields.function.title",
        "description" : "fields.function.description",
        "minLength" : 1
      },
      "huggingface_task" : {
        "$ref" : "#/$defs/HuggingfaceTask",
        "title" : "fields.huggingface.task.title",
        "description" : "fields.huggingface.task.description"
      },
      "max_length" : {
        "type" : "integer",
        "title" : "fields.huggingface.maxlength.title",
        "description" : "fields.huggingface.maxlength.description"
      },
      "max_log_len" : {
        "type" : "integer",
        "title" : "fields.huggingface.maxloglen.title",
        "description" : "fields.huggingface.maxloglen.description"
      },
      "profile" : {
        "type" : "string",
        "title" : "fields.profile.title",
        "description" : "fields.profile.description"
      },
      "replicas" : {
        "type" : "integer",
        "title" : "fields.replicas.title",
        "description" : "fields.replicas.description",
        "minimum" : 0
      },
      "resources" : {
        "$ref" : "#/$defs/CoreResource",
        "title" : "fields.resources.title",
        "description" : "fields.resources.description"
      },
      "return_probabilities" : {
        "type" : "boolean",
        "title" : "fields.huggingface.returnprobabilities.title",
        "description" : "fields.huggingface.returnprobabilities.description"
      },
      "return_token_type_ids" : {
        "type" : "boolean",
        "title" : "fields.huggingface.returntokentypeids.title",
        "description" : "fields.huggingface.returntokentypeids.description"
      },
      "secrets" : {
        "title" : "fields.secrets.title",
        "description" : "fields.secrets.description",
        "type" : "array",
        "items" : {
          "type" : "string",
          "title" : "fields.secrets.item.title",
          "description" : "fields.secrets.item.description"
        }
      },
      "service_name" : {
        "type" : "string",
        "title" : "fields.serviceName.title",
        "description" : "fields.serviceName.description"
      },
      "service_type" : {
        "$ref" : "#/$defs/CoreServiceType",
        "title" : "fields.serviceType.title",
        "description" : "fields.serviceType.description",
        "default" : "ClusterIP"
      },
      "tensor_input_names" : {
        "title" : "fields.huggingface.tensorinputnames.title",
        "description" : "fields.huggingface.tensorinputnames.description",
        "type" : "array",
        "items" : {
          "type" : "string",
          "title" : "fields.tensorInputNames.item.title",
          "description" : "fields.tensorInputNames.item.description"
        }
      },
      "tokenizer_revision" : {
        "type" : "string",
        "title" : "fields.huggingface.tokenizerrevision.title",
        "description" : "fields.huggingface.tokenizerrevision.description"
      },
      "trust_remote_code" : {
        "type" : "boolean",
        "title" : "fields.huggingface.trustremotecode.title",
        "description" : "fields.huggingface.trustremotecode.description"
      },
      "volumes" : {
        "title" : "fields.volumes.title",
        "description" : "fields.volumes.description",
        "type" : "array",
        "items" : {
          "$ref" : "#/$defs/CoreVolume",
          "title" : "fields.volumes.item.title",
          "description" : "fields.volumes.item.description"
        }
      }
    },
    "required" : [ "function" ],
    "title" : "specs.huggingfaceserve+serve.title",
    "description" : "specs.huggingfaceserve+serve.description"
  } ]
}