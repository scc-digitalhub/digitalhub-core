digraph chaining {
  rankdir=LR;
  bgcolor="transparent";
  node [shape=box, style="rounded,filled", fontname="DejaVu Sans", fontsize=11, penwidth=1.3, margin="0.12,0.07"];
  edge [color="#5b6b7a", penwidth=1.1];

  src     [label="source\n.onnx", fillcolor="white", color="#145a86"];
  build   [label="tvm+build\n(Job)", fillcolor="#eef3f8", color="#145a86"];
  ir      [label="function.spec\nir_model  (tvm-ir Model)", fillcolor="#fbf3da", color="#d4a017"];
  compile [label="tvm+compile\n(Job · compiler.py → model.so)", fillcolor="#eef3f8", color="#145a86"];
  so      [label="function.spec\nso_model  (tvm-so Model)", fillcolor="#fbf3da", color="#d4a017"];
  serve   [label="tvm+serve\n(model-centric)", fillcolor="#e7f0e7", color="#3a7d44"];
  ep      [label="endpoint\nOpenInference v2", fillcolor="#e7f0e7", color="#3a7d44"];

  src -> build -> ir -> compile -> so -> serve -> ep;
}
