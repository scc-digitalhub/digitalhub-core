digraph overview {
  rankdir=TB;
  bgcolor="transparent";
  node [shape=box, style="rounded,filled", fontname="DejaVu Sans", fontsize=11, penwidth=1.3, margin="0.12,0.07"];
  edge [color="#5b6b7a", penwidth=1.1, fontname="DejaVu Sans", fontsize=9];

  client [label="Console / SDK / curl", fillcolor="#fbf3da", color="#d4a017"];
  core   [label="digitalhub-core (Spring Boot)\n@RuntimeComponent(\"tvm\")\nbuild · onBuilt · run · onComplete · onRunning", fillcolor="#dde9f3", color="#145a86"];

  subgraph cluster_k8s {
    label="Kubernetes (minikube)";
    fontname="DejaVu Sans"; fontsize=11; color="#9bb0c2"; style="rounded"; bgcolor="#f7fafc";
    job      [label="Job  tvm+build / tvm+compile\n(tvm-toolkit · plain Job, no Kaniko)", fillcolor="#eef3f8", color="#145a86"];
    serve    [label="Deployment + Service  tvm+serve\n(model-centric · native tvm-serve · Rust · KServe v2)", fillcolor="#e7f0e7", color="#3a7d44"];
    minio    [label="MinIO (S3)\nbucket digitalhub", fillcolor="#f3e7ef", color="#8e4585"];
  }

  client -> core     [label="REST /api/v1"];
  core   -> job      [label="kubeconfig"];
  core   -> serve    [label="kubeconfig"];
  job    -> minio    [label="build/compile: Model on S3 (SDK)"];
  minio  -> serve    [label="init container: download tvm-so model.so", style=dashed];
  client -> serve    [label="/v2/.../infer", style=dashed, constraint=false];
}
