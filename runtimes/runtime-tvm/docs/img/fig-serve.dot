digraph serve {
  rankdir=TB;
  bgcolor="transparent";
  node [shape=box, style="rounded,filled", fontname="DejaVu Sans", fontsize=11, penwidth=1.3, margin="0.14,0.08"];
  edge [color="#5b6b7a", penwidth=1.1, fontname="DejaVu Sans", fontsize=9];

  a [label="POST run  tvm+serve:run", fillcolor="#fbf3da", color="#d4a017"];
  b [label="TvmServeRunner.produce() → K8sServeRunnable\nmodel = task.model_path | function.spec.so_model  (tvm-so Model)\nimage = task.image | runtime.tvm.serve  (swappable base)", fillcolor="#eef3f8", color="#145a86"];
  c [label="K8s: Deployment + Service (ClusterIP / NodePort) · ports 8080 / 9000", fillcolor="#eef3f8", color="#145a86"];

  subgraph cluster_pod {
    label="Pod  (generic serve image · model downloaded at deploy time)"; fontname="DejaVu Sans"; fontsize=10; color="#3a7d44"; style="rounded"; bgcolor="#f3f8f3";
    init [label="init container: download s3://…/<tvm-so>/ → <home>/model/\n(model.so + metadata.json)", fillcolor="#e7f0e7", color="#3a7d44"];
    d [label="ENTRYPOINT: native tvm-serve (Rust default; Go planned)", fillcolor="#e7f0e7", color="#3a7d44"];
    e [label="load <home>/model/model.so → Relax VM (dedicated thread)\nTVM_MODEL_DIR + TVM_MODEL_NAME from env", fillcolor="#e7f0e7", color="#3a7d44"];
    f [label="KServe / Open Inference v2:  REST :8080  ·  gRPC :9000", fillcolor="#e7f0e7", color="#3a7d44"];
  }

  client [label="Client", fillcolor="#fbf3da", color="#d4a017"];

  a -> b -> c -> init -> d -> e -> f;
  client -> f [label="POST /v2/models/<served_name>/infer", style=dashed, constraint=false];
}
